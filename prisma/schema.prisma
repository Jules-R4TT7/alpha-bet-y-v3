generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Auth models (NextAuth)
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  username      String?   @unique
  password      String?
  isGuest       Boolean   @default(false)

  accounts Account[]
  sessions Session[]

  // Game data
  rating      Int     @default(1000)
  gamesPlayed Int     @default(0)
  gamesWon    Int     @default(0)
  totalScore  Int     @default(0)
  streak      Int     @default(0)
  bestStreak  Int     @default(0)

  gamePlayersA GamePlayer[]
  challenges   DailyChallengeEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rating])
  @@index([username])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Game models
model Game {
  id        String     @id @default(cuid())
  status    GameStatus @default(WAITING)
  mode      GameMode   @default(RANKED)
  rounds    Int        @default(3)
  timeLimit Int        @default(20) // seconds per round

  players GamePlayer[]

  currentRound  Int     @default(0)
  currentLetter String?

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
}

model GamePlayer {
  id     String @id @default(cuid())
  gameId String
  userId String
  score  Int    @default(0)
  result GameResult?

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])
  words GameWord[]

  @@unique([gameId, userId])
  @@index([userId])
}

model GameWord {
  id           String @id @default(cuid())
  gamePlayerId String
  word         String
  round        Int
  points       Int
  playedAt     DateTime @default(now())

  gamePlayer GamePlayer @relation(fields: [gamePlayerId], references: [id], onDelete: Cascade)

  @@index([gamePlayerId, round])
}

model DailyChallenge {
  id      String   @id @default(cuid())
  date    DateTime @unique @db.Date
  letter  String
  target  Int      @default(10)
  entries DailyChallengeEntry[]

  createdAt DateTime @default(now())
}

model DailyChallengeEntry {
  id          String @id @default(cuid())
  challengeId String
  userId      String
  score       Int
  wordsPlayed Int
  completedAt DateTime @default(now())

  challenge DailyChallenge @relation(fields: [challengeId], references: [id])
  user      User           @relation(fields: [userId], references: [id])

  @@unique([challengeId, userId])
  @@index([challengeId, score(sort: Desc)])
}

enum GameStatus {
  WAITING
  BIDDING
  PLAYING
  COMPLETED
}

enum GameMode {
  RANKED
  CASUAL
  DAILY
}

enum GameResult {
  WIN
  LOSS
  DRAW
}
